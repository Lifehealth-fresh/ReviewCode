@model IEnumerable<QLBH.BLL.DTOs.BienTheSanPhamDto>

@{
    ViewData["Title"] = "Quản lý biến thể sản phẩm";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="fas fa-tags text-primary"></i>
            Quản lý biến thể sản phẩm
        </h2>

        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i>
                Thêm biến thể
            </a>

            @if (ViewBag.SanPhamId != null)
            {
                <a href="/BienTheSanPham" class="btn btn-secondary">
                    <i class="fas fa-list"></i>
                    Xem tất cả
                </a>
            }
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Sản phẩm</th>
                                <th>Size</th>
                                <th>Màu sắc</th>
                                <th>Giá</th>
                                <th>Tồn kho</th>
                                <th>Trạng thái</th>
                                <th width="180">Thao tác</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        <span class="fw-bold text-secondary">
                                            #@item.BienTheID
                                        </span>
                                    </td>

                                    <td>
                                        <div class="fw-semibold">
                                            @item.TenSanPham
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge bg-info text-dark px-3 py-2">
                                            @item.Size
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary px-3 py-2">
                                            @item.MauSac
                                        </span>
                                    </td>

                                    <td class="text-danger fw-bold">
                                        @item.Gia.ToString("N0") đ
                                    </td>

                                    <td>
                                        @if (item.SoLuongTon > 10)
                                        {
                                            <span class="badge bg-success">
                                                @item.SoLuongTon sản phẩm
                                            </span>
                                        }
                                        else if (item.SoLuongTon > 0)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Sắp hết (@item.SoLuongTon)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Hết hàng
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        @if (item.TrangThai)
                                        {
                                            <span class="badge bg-success">
                                                Hoạt động
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Khóa
                                            </span>
                                        }
                                    </td>

                                    <td>

                                        <a asp-action="Edit"
                                               asp-route-id="@item.BienTheID"
                                               class="btn btn-sm btn-warning me-1">
                                            <i class="fas fa-edit"></i>
                                            Sửa
                                        </a>

                                        <a asp-action="Delete"
                                               asp-route-id="@item.BienTheID"
                                               class="btn btn-sm btn-danger"
                                               onclick="return confirm('Bạn có chắc muốn xóa biến thể này?')">
                                            <i class="fas fa-trash"></i>
                                            Xóa
                                        </a>

                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning shadow-sm">
            <h5 class="mb-2">
                <i class="fas fa-box-open"></i>
                Chưa có biến thể sản phẩm
            </h5>

            <p class="mb-0">
                Hãy thêm biến thể đầu tiên cho hệ thống.
            </p>
        </div>
    }

</div>