<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f4f6f9; }
        .sidebar { height: 100vh; background: #2c3e50; color: white; position: fixed; top: 0; left: 0; width: 260px; overflow-y: auto; }
        .sidebar a { color: #ecf0f1; text-decoration: none; display: block; padding: 12px 20px; transition: 0.3s; }
        .sidebar a:hover { background: #1a252f; }
        .sidebar i { margin-right: 10px; width: 20px; }
        .main-content { margin-left: 260px; padding: 20px; }
        .navbar-top { background: white; padding: 10px 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); margin-bottom: 20px; border-radius: 10px; }
        .footer { text-align: center; margin-top: 30px; color: #6c757d; }
        .active-menu { background: #1a252f; border-left: 4px solid #ff6a00; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="text-center py-3 border-bottom">
            <h4><i class="fas fa-tshirt"></i> FashionStore</h4>
            <small>Admin Panel</small>
        </div>
        <div class="mt-3">
            <li class="nav-item">
            <a href="/QuanLyKho"><i class="fas fa-warehouse"></i> Quản lý kho</a>
            <a href="/DanhMuc"><i class="fas fa-list"></i> Quản lý danh mục</a>
            <a href="/SanPham/Admin"><i class="fas fa-box"></i> Quản lý sản phẩm</a>
            <a href="/BienTheSanPham"><i class="fas fa-palette"></i> Quản lý biến thể</a>
            <a href="/Voucher"><i class="fas fa-ticket-alt"></i> Quản lý voucher</a>
            <a href="/ThanhToan"><i class="fas fa-credit-card"></i> Duyệt thanh toán</a>
            <a href="/DonHang/QuanLy"><i class="fas fa-truck"></i> Quản lý đơn hàng</a>
            <a href="/ThongKe"><i class="fas fa-chart-line"></i> Thống kê</a>
            <a href="/TaiKhoan/DanhSach"><i class="fas fa-users"></i> Quản lý tài khoản</a>

            @* === THÊM MỤC THÔNG TIN CÁ NHÂN CHO NHÂN VIÊN === *@
            @if (User.Identity.IsAuthenticated && User.IsInRole("NhanVien"))
            {
                <a href="/TaiKhoan/ThongTin"><i class="fas fa-user-circle"></i> Thông tin cá nhân</a>
            }

            <hr class="bg-light" />
            <a href="/"><i class="fas fa-home"></i> Về trang chủ</a>
            <a href="/TaiKhoan/DangXuat"><i class="fas fa-sign-out-alt"></i> Đăng xuất</a>
        </div>
    </div>
    <div class="main-content">
        <div class="navbar-top d-flex justify-content-between">
            <h3 class="mb-0">@ViewData["Title"]</h3>
            <div><i class="fas fa-user-circle"></i> @User.Identity?.Name</div>
        </div>
        @RenderBody()
        <div class="footer">
            &copy; 2026 FashionStore - Đồ án Lập trình CSDL
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right" };
        @if (TempData["Success"] != null) { <text>toastr.success('@TempData["Success"]');</text> }
        @if (TempData["Error"] != null) { <text>toastr.error('@TempData["Error"]');</text> }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>