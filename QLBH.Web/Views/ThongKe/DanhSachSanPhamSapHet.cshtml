@model List<QLBH.BLL.DTOs.SanPhamSapHetDto>
@{
    ViewData["Title"] = "Sản phẩm sắp hết";
}
<h2>Sản phẩm sắp hết (tồn kho ≤ 10)</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">Không có sản phẩm nào sắp hết.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr><th>Tên sản phẩm</th><th>Size</th><th>Số lượng tồn</th></tr>
        </thead>
        <tbody>
            @foreach (var sp in Model)
            {
                <tr>
                    <td>@sp.TenSanPham</td>
                    <td>@sp.Size</td>
                    <td>@sp.SoLuongTon</td>
                </tr>
            }
        </tbody>
    </table>
}
<a asp-action="Index" class="btn btn-secondary">Quay lại</a>