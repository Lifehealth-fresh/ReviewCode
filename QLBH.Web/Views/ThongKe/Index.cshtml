@model QLBH.BLL.DTOs.DashboardSummaryDto
@{
    ViewData["Title"] = "Dashboard";
}
<h2>Tổng quan kinh doanh</h2>
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Tổng doanh thu</h5>
                <p class="card-text display-6">@Model.TongDoanhThu.ToString("N0") đ</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Đơn hàng thành công</h5>
                <p class="card-text display-6">@Model.TongDonHangThanhCong</p>
                <a asp-action="DanhSachDonHangThanhCong" class="btn btn-light btn-sm mt-2">Xem chi tiết</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Sản phẩm sắp hết</h5>
                <p class="card-text display-6">@Model.SoSanPhamSapHetHang</p>
                <a asp-action="DanhSachSanPhamSapHet" class="btn btn-light btn-sm mt-2">Xem chi tiết</a>
            </div>
        </div>
    </div>

<h3>Top 5 sản phẩm bán chạy</h3>
<table class="table table-bordered">
    <thead>
        <tr><th>Tên sản phẩm</th><th>Size</th><th>Số lượng bán</th><th>Doanh thu</th></tr>
    </thead>
    <tbody>
        @foreach (var sp in Model.TopSanPhamBanChay)
        {
            <tr><td>@sp.TenSanPham</td><td>@sp.Size</td><td>@sp.SoLuongDaBan</td><td>@sp.DoanhThuMangLai.ToString("N0") đ</td></tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-action="DoanhThuTheoNgay" class="btn btn-secondary">Doanh thu theo ngày</a>
    <a asp-action="DoanhThuTheoThang" class="btn btn-secondary">Doanh thu theo tháng</a>
    <a asp-action="DoanhThuTheoDanhMuc" class="btn btn-secondary">Doanh thu theo danh mục</a>

    <!-- Dropdown xuất XML -->
    <div class="btn-group">
        <button type="button" class="btn btn-info dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            Xuất XML
        </button>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" asp-action="ExportXml" asp-route-type="dashboard">Xuất Dashboard</a></li>
            <li><a class="dropdown-item" asp-action="ExportXml" asp-route-type="ngay">Xuất Doanh thu theo ngày</a></li>
            <li><a class="dropdown-item" asp-action="ExportXml" asp-route-type="thang">Xuất Doanh thu theo tháng</a></li>
            <li><a class="dropdown-item" asp-action="ExportXml" asp-route-type="danhmuc">Xuất Doanh thu theo danh mục</a></li>
        </ul>
    </div>
</div>