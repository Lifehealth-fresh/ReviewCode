@model QLBH.BLL.DTOs.UpdateVoucherDto
@{
    ViewData["Title"] = "Sửa voucher";
}
<h2>Sửa voucher: @Model.MaVoucher</h2>
<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="VoucherID" />
    <input type="hidden" asp-for="DaSuDung" />
    <p asp-validation-summary="ModelOnly" class="text-danger"></p>

    <p class="mb-3">
        <label asp-for="MaVoucher" class="form-label">Mã voucher</label>
        <input asp-for="MaVoucher" class="form-control" required />
    </p>
    <p class="mb-3">
        <label asp-for="MoTa" class="form-label">Mô tả</label>
        <input asp-for="MoTa" class="form-control" />
    </p>
    <p class="mb-3">
        <label asp-for="LoaiGiam" class="form-label">Loại giảm</label>
        <select asp-for="LoaiGiam" class="form-control">
            <option value="PhanTram">Phần trăm (%)</option>
            <option value="TienMat">Tiền mặt (VNĐ)</option>
        </select>
    </p>
    <p class="row">
        <span class="col-md-4 mb-3 d-inline-block">
            <label asp-for="GiaTriGiam" class="form-label">Giá trị giảm</label>
            <input asp-for="GiaTriGiam" class="form-control" type="number" step="any" min="0" required />
        </span>
        <span class="col-md-4 mb-3 d-inline-block">
            <label asp-for="DonToiThieu" class="form-label">Đơn tối thiểu</label>
            <input asp-for="DonToiThieu" class="form-control" type="number" step="any" min="0" />
        </span>
        <span class="col-md-4 mb-3 d-inline-block">
            <label asp-for="GiamToiDa" class="form-label">Giảm tối đa (nếu %)</label>
            <input asp-for="GiamToiDa" class="form-control" type="number" step="any" min="0" />
        </span>
    </p>
    <p class="row">
        <span class="col-md-4 mb-3 d-inline-block">
            <label asp-for="SoLuong" class="form-label">Số lượng</label>
            <input asp-for="SoLuong" class="form-control" type="number" min="1" required />
        </span>
        <span class="col-md-4 mb-3 d-inline-block">
            <label asp-for="NgayBatDau" class="form-label">Ngày bắt đầu</label>
            <input asp-for="NgayBatDau" class="form-control" type="date" required />
        </span>
        <span class="col-md-4 mb-3 d-inline-block">
            <label asp-for="NgayKetThuc" class="form-label">Ngày kết thúc</label>
            <input asp-for="NgayKetThuc" class="form-control" type="date" required />
        </span>
    </p>
    <p class="mb-3 form-check">
        <input asp-for="TrangThai" class="form-check-input" />
        <label asp-for="TrangThai" class="form-check-label">Kích hoạt</label>
    </p>
    <p class="text-muted">Đã sử dụng: @Model.DaSuDung lượt</p>
    <button type="submit" class="btn btn-primary">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
